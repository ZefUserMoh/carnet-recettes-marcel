<div class="edit-recipe-container">
    <h1><%= recipe ? '✏️ Modifier la recette' : '➕ Ajouter une nouvelle recette' %></h1>
    
    <form action="<%= recipe ? '/admin/recipes/edit/' + recipe._id : '/admin/recipes/add' %>" method="POST" enctype="multipart/form-data">
        <div class="form-group">
            <label for="title">Titre de la recette :</label>
            <input type="text" id="title" name="title" value="<%= recipe ? recipe.title : '' %>" required placeholder="Ex: Ma tarte aux pommes">
        </div>

        <div class="form-group">
            <label for="description">Petite description :</label>
            <textarea id="description" name="description" rows="3" placeholder="Une petite histoire sur cette recette..."><%= recipe ? recipe.description : '' %></textarea>
        </div>

        <div class="form-group">
            <label for="ingredients">Ingrédients (un par ligne) :</label>
            <textarea id="ingredients" name="ingredients" rows="6" required placeholder="2 œufs&#10;100g de sucre&#10;..."><%= recipe ? recipe.ingredients.join('\n') : '' %></textarea>
        </div>

        <div class="form-group">
            <label for="steps">Étapes de préparation (une par ligne) :</label>
            <textarea id="steps" name="steps" rows="8" required placeholder="Éplucher les pommes.&#10;Préchauffer le four à 180°C.&#10;..."><%= recipe ? recipe.steps.join('\n') : '' %></textarea>
        </div>

        <div class="form-group">
            <label for="image">Image de la recette :</label>
            <% if (recipe && recipe.imageUrl) { %>
                <div class="current-image">
                    <p>Image actuelle :</p>
                    <img src="<%= recipe.imageUrl %>" alt="Aperçu" style="max-width: 200px; margin-bottom: 10px; border-radius: 5px; border: 1px solid #ddd;">
                </div>
            <% } %>
            <input type="file" id="image" name="image" accept="image/*">
            <small>Marcel, choisissez une belle photo sur votre ordinateur.</small>
        </div>

        <div class="actions">
            <button type="submit" class="btn-save">💾 Enregistrer la recette</button>
            <a href="/admin/dashboard" class="btn-cancel">Annuler</a>
        </div>
    </form>
</div>

<style>
    .edit-recipe-container {
        max-width: 800px;
        margin: 20px auto;
        padding: 30px;
        background: #fdf6e3;
        border: 2px solid #8b4513;
        border-radius: 10px;
        font-family: 'Courier New', Courier, monospace;
    }

    h1 { color: #8b4513; border-bottom: 2px solid #8b4513; padding-bottom: 10px; }

    .form-group { margin-bottom: 20px; }

    label { display: block; font-weight: bold; color: #5d2906; margin-bottom: 5px; }

    input, textarea {
        width: 100%;
        padding: 10px;
        border: 1px solid #d2b48c;
        border-radius: 5px;
        background: #fff;
        font-family: inherit;
    }

    .actions { display: flex; gap: 15px; align-items: center; margin-top: 30px; }

    .btn-save {
        background: #28a745;
        color: white;
        padding: 12px 25px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 1.1em;
        font-weight: bold;
    }

    .btn-cancel {
        color: #666;
        text-decoration: none;
    }

    .btn-save:hover { background: #218838; }
</style>
