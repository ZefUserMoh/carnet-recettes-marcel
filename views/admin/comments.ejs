<div class="dashboard-container">
    <h1>🧹 Modération des Commentaires</h1>
    <p>Marcel, c'est ici que vous pouvez retirer les messages qui ne vous plaisent pas.</p>
    
    <div class="actions">
        <a href="/admin/dashboard" class="btn secondary">⬅ Retour au tableau de bord</a>
    </div>

    <table class="comments-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Auteur</th>
                <th>Recette</th>
                <th>Message</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if (comments.length === 0) { %>
                <tr>
                    <td colspan="5" style="text-align: center;">Aucun commentaire pour le moment.</td>
                </tr>
            <% } else { %>
                <% comments.forEach(comment => { %>
                    <tr>
                        <td><%= new Date(comment.createdAt).toLocaleDateString('fr-FR') %></td>
                        <td><strong><%= comment.author %></strong></td>
                        <td><%= comment.recipeId ? comment.recipeId.title : '(Recette supprimée)' %></td>
                        <td><%= comment.content %></td>
                        <td>
                            <a href="/admin/comments/delete/<%= comment._id %>" 
                               class="btn-delete" 
                               onclick="return confirm('Supprimer ce message définitivement ?')">
                               🗑️ Supprimer
                            </a>
                        </td>
                    </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
</div>

<style>
    .dashboard-container { padding: 40px; background: #fff; }
    h1 { color: #8b4513; }
    .actions { margin-bottom: 30px; }
    
    .btn { padding: 10px 20px; text-decoration: none; border-radius: 5px; font-weight: bold; }
    .btn.secondary { background: #007bff; color: white; }

    .comments-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        background: #fafafa;
    }

    .comments-table th, .comments-table td {
        border: 1px solid #ddd;
        padding: 12px;
        text-align: left;
    }

    .comments-table th {
        background: #f4ebd0;
        color: #5d2906;
    }

    .comments-table tr:hover { background: #fdf6e3; }

    .btn-delete {
        color: #dc3545;
        text-decoration: none;
        font-weight: bold;
    }
</style>
