<div class="dashboard-container">
    <h1>👨‍🍳 Bienvenue dans votre cuisine, Marcel !</h1>
    <p>C'est ici que vous pouvez gérer vos précieuses recettes.</p>
    
    <div class="actions">
        <a href="/admin/recipes/add" class="btn">➕ Ajouter une nouvelle recette</a>
        <a href="/admin/comments" class="btn comment-btn">💬 Gérer les commentaires</a>
        <a href="/" class="btn secondary">👁️ Voir le blog public</a>
        <a href="/logout" class="btn logout">🚪 Se déconnecter</a>
    </div>

    <section class="recipe-list">
        <h3>Vos recettes publiées (<%= recipes.length %>) :</h3>
        
        <% if (recipes.length === 0) { %>
            <p><i>Vous n'avez pas encore de recettes. Commencez par en ajouter une !</i></p>
        <% } else { %>
            <div class="recipes-grid">
                <% recipes.forEach(recipe => { %>
                    <div class="recipe-card">
                        <h4><%= recipe.title %></h4>
                        <p><%= recipe.description.substring(0, 100) %>...</p>
                        <div class="card-actions">
                            <a href="/admin/recipes/edit/<%= recipe._id %>" class="btn-edit">✏️ Modifier</a>
                            <a href="/admin/recipes/delete/<%= recipe._id %>" class="btn-delete" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette recette ?')">🗑️ Supprimer</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </section>
</div>

<style>
    .dashboard-container { padding: 40px; background: #fff; border-radius: 8px; }
    h1 { color: #8b4513; }
    .actions { margin: 30px 0; display: flex; flex-wrap: wrap; gap: 15px; }
    
    .btn { padding: 12px 25px; text-decoration: none; border-radius: 5px; font-weight: bold; }
    .btn.comment-btn { background: #ffc107 !important; color: #333 !important; }
    .btn.secondary { background: #007bff !important; color: white !important; }
    .btn.logout { background: #dc3545 !important; color: white !important; }

    .recipes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .recipe-card {
        padding: 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background: #f9f9f9;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .card-actions {
        margin-top: 15px;
        display: flex;
        justify-content: space-between;
    }

    .btn-edit { color: #007bff; text-decoration: none; font-weight: bold; }
    .btn-delete { color: #dc3545; text-decoration: none; font-weight: bold; }
</style>
