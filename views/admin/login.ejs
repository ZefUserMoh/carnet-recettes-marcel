<div class="login-container">
    <h2>🔑 Connexion au carnet de Papy Marcel</h2>
    
    <% if (error) { %>
        <p class="error-msg"><%= error %></p>
    <% } %>

    <form action="/login" method="POST">
        <div class="form-group">
            <label for="username">Nom d'utilisateur :</label>
            <input type="text" id="username" name="username" required placeholder="Ex: PapyMarcel">
        </div>

        <div class="form-group">
            <label for="password">Mot de passe :</label>
            <input type="password" id="password" name="password" required placeholder="********">
        </div>

        <button type="submit" class="btn-submit">S'identifier</button>
    </form>
</div>

<style>
    .login-container {
        max-width: 400px;
        margin: 50px auto;
        padding: 30px;
        background: #fdf6e3;
        border: 2px solid #8b4513;
        border-radius: 10px;
        box-shadow: 5px 5px 15px rgba(0,0,0,0.1);
        text-align: center;
        font-family: 'Courier New', Courier, monospace;
    }

    h2 {
        color: #8b4513;
        border-bottom: 2px dashed #8b4513;
        padding-bottom: 10px;
    }

    .form-group {
        margin-bottom: 20px;
        text-align: left;
    }

    label {
        display: block;
        font-weight: bold;
        color: #5d2906;
    }

    input {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        border: 1px solid #d2b48c;
        border-radius: 5px;
        background: #fff;
    }

    .btn-submit {
        background: #8b4513;
        color: white;
        padding: 12px 20px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        width: 100%;
        font-size: 1.1em;
        transition: background 0.3s;
    }

    .btn-submit:hover {
        background: #5d2906;
    }

    .error-msg {
        color: #b22222;
        font-weight: bold;
        margin-bottom: 15px;
    }
</style>
